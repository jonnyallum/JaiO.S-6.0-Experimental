# Jai.OS 6.0 — Environment Variables
# Copy to .env and fill in your values. Never commit .env.

# -----------------------------------------------------------------------
# Required: Claude API (for @hugo and all agent nodes)
# -----------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------
# Required: GitHub REST API
# Without a token: 60 requests/hr (public repos only)
# With a token:    5,000 requests/hr
# Create at: https://github.com/settings/tokens (fine-grained, read-only)
# -----------------------------------------------------------------------
GITHUB_TOKEN=github_pat_...

# -----------------------------------------------------------------------
# Required: Supabase state persistence
# Use the Antigravity Shared Brain (lkwydqtfbdjhxaarelaz) or a dedicated project
# -----------------------------------------------------------------------
ANTIGRAVITY_BRAIN_URL=https://lkwydqtfbdjhxaarelaz.supabase.co
ANTIGRAVITY_BRAIN_SERVICE_ROLE_KEY=eyJ...

# Alternative: point to a different Supabase project
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
